# =============================================================================
# Family Hub - Docker Ignore
# =============================================================================

# Git
.git/
.gitignore

# Dependencies (will be installed in container)
node_modules/
__pycache__/
venv/
.venv/

# Build artifacts (will be built in container)
frontend/build/
dist/

# IDE
.idea/
.vscode/
*.swp

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Testing
coverage/
.pytest_cache/
test_reports/
backend/tests/
backend/__init__.py
tests/

# Docker files (don't need to copy themselves)
Dockerfile*
docker-compose*.yml
.dockerignore

# Documentation (except README)
*.md
!README.md
!ANDROID_BUILD.md

# Environment (use runtime env vars)
.env
.env.*
!.env.example
backend/.env
frontend/.env

# Android (not needed for Docker)
frontend/android/

# Misc
*.bak
*.tmp
.emergent/
memory/
cliff.toml
LICENSE
