{
  "appId": "com.familyhub.app",
  "appName": "Family Hub",
  "webDir": "build",
  "server": {
    "androidScheme": "https",
    "allowNavigation": ["*"]
  },
  "plugins": {
    "Camera": {
      "presentationStyle": "popover"
    },
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#F4F1DE",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false
    }
  },
  "android": {
    "allowMixedContent": true,
    "captureInput": true,
    "webContentsDebuggingEnabled": false
  }
}
